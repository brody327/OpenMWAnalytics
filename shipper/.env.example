# Copy to shipper/.env (gitignored) and fill in the real value.
#
# The ingest token required by POST /events on the cloud API. It must match the
# OMWA_INGEST_TOKEN in the cluster's omwa-api-secrets Secret. Read the current value with:
#
#   kubectl get secret omwa-api-secrets -o jsonpath='{.data.OMWA_INGEST_TOKEN}' | base64 -d
#
# start-shipper.ps1 reads this file automatically.
OMWA_INGEST_TOKEN=

# Ingest provenance: 'dev' | 'prod'.
#
#   dev  = the MOD AUTHOR's machine
#   prod = a genuine third-party player
#
# The boundary is the SOURCE, not intent. Author data is unrepresentative however
# carefully you play: you know the solution, you know which evidence matters, you know
# where the vents are. You cannot be a naive player of your own mod. So the author's
# machine stays 'dev' for every session -- testing or not.
#
# Leave this unset on a distributed shipper: the default is 'prod', which is correct for
# a real player and wrong (visibly, correctably) for you.
OMWA_ENV=dev
