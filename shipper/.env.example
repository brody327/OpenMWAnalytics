# Copy to shipper/.env (gitignored) and fill in the real value.
#
# The ingest token required by POST /events on the cloud API. It must match the
# OMWA_INGEST_TOKEN in the cluster's omwa-api-secrets Secret. Read the current value with:
#
#   kubectl get secret omwa-api-secrets -o jsonpath='{.data.OMWA_INGEST_TOKEN}' | base64 -d
#
# start-shipper.ps1 reads this file automatically.
OMWA_INGEST_TOKEN=
