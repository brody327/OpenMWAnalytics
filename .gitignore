# --- Dependencies -----------------------------------------------------------
# Matches node_modules at any depth (api/, future packages/*, dashboard/, ...).
node_modules/

# --- Build output -----------------------------------------------------------
dist/
build/
*.tsbuildinfo

# --- Secrets / local env ----------------------------------------------------
# Never commit real env files. The *.example files ARE committed as the
# documented template. Keep it this way BEFORE .env ever holds a real secret:
# git history is permanent, so an untracked secret is a non-event, a tracked
# one is a history rewrite.
.env
.env.local
.env.*.local
!.env.example
aws.txt
omwa-key.pem

# --- Logs / runtime scratch -------------------------------------------------
*.log
*.pid

# Shipper durable-offset checkpoint (per-machine runtime state, not source).
shipper/.ship-state.json

# --- Editor / OS cruft ------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
*.swp
