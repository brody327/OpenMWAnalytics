# Copy to .env. These match docker-compose.yml.
DATABASE_URL=postgresql://omwa:omwa_dev_pw@localhost:5432/omwanalytics
PORT=4000

# Shared bearer token required by POST /events (the only write path; /stats/* stay public).
# The API FAILS CLOSED: if this is unset, ingest returns 503 and logs loudly rather than
# silently accepting unauthenticated writes. The shipper must send the same value as
# OMWA_INGEST_TOKEN. In production this lives in the k8s Secret, never in git.
#   generate one:  node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
OMWA_INGEST_TOKEN=dev_local_token_change_me
